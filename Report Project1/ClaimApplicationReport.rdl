<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df">
	<df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
	<ReportParameters>
		<ReportParameter Name="ReportDate">
			<DataType>String</DataType>
			<Prompt>Report Date</Prompt>
		</ReportParameter>
		<ReportParameter Name="ReportAmount">
			<DataType>String</DataType>
			<Prompt>Report Amount</Prompt>
		</ReportParameter>
		<ReportParameter Name="TotalTransactions">
			<DataType>String</DataType>
			<Prompt>Total Transactions</Prompt>
		</ReportParameter>
	</ReportParameters>
	<ReportSections>
		<ReportSection>
			<Body>
				<ReportItems>

					<!-- Left Address Block -->
					<Textbox Name="TxtAddress">
						<CanGrow>true</CanGrow>
						<KeepTogether>true</KeepTogether>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>The Chief Manager,</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>State Bank of Pakistan (SBP),</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Banking Services Corporation (BSC),</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Karachi Office (KO).</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
						<Top>0.2in</Top>
						<Left>0.25in</Left>
						<Height>0.75in</Height>
						<Width>3.5in</Width>
						<Style>
							<Border>
								<Style>None</Style>
							</Border>
						</Style>
					</Textbox>

					<!-- Dated Label (top right) -->
					<Textbox Name="TxtDated">
						<CanGrow>true</CanGrow>
						<KeepTogether>true</KeepTogether>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Dated: </Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
									<TextRun>
										<Value>=Parameters!ReportDate.Value</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
								<Style>
									<TextAlign>Right</TextAlign>
								</Style>
							</Paragraph>
						</Paragraphs>
						<Top>0.2in</Top>
						<Left>4.5in</Left>
						<Height>0.25in</Height>
						<Width>2.25in</Width>
						<Style>
							<Border>
								<Style>None</Style>
							</Border>
						</Style>
					</Textbox>

					<!-- Subject Line -->
					<Textbox Name="TxtSubject">
						<CanGrow>true</CanGrow>
						<KeepTogether>true</KeepTogether>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Subject:  Claim Application for Reimbursement of T.T. Charges against Home Remittance for the Month of </Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
											<FontWeight>Bold</FontWeight>
											<TextDecoration>Underline</TextDecoration>
										</Style>
									</TextRun>
									<TextRun>
										<Value>=Parameters!ReportDate.Value</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
											<FontWeight>Bold</FontWeight>
											<TextDecoration>Underline</TextDecoration>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
						<Top>1.1in</Top>
						<Left>0.25in</Left>
						<Height>0.3in</Height>
						<Width>6.5in</Width>
						<Style>
							<Border>
								<Style>None</Style>
							</Border>
						</Style>
					</Textbox>

					<!-- Body Paragraph 1 -->
					<Textbox Name="TxtBody1">
						<CanGrow>true</CanGrow>
						<KeepTogether>true</KeepTogether>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>In terms of EPD Circular Letter No. 04 of 2025 dated June 30, 2025, we submit herewith claim for the month of </Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
									<TextRun>
										<Value>=Parameters!ReportDate.Value</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
									<TextRun>
										<Value> having total </Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
									<TextRun>
										<Value>=Parameters!TotalTransactions.Value</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
									<TextRun>
										<Value> transactions amounting </Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
									<TextRun>
										<Value>PKR </Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
											<FontWeight>Bold</FontWeight>
										</Style>
									</TextRun>
									<TextRun>
										<Value>=Parameters!ReportAmount.Value</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
											<FontWeight>Bold</FontWeight>
										</Style>
									</TextRun>
									<TextRun>
										<Value> as per calculations mentioned in below table:</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
						<Top>1.55in</Top>
						<Left>0.25in</Left>
						<Height>0.6in</Height>
						<Width>6.5in</Width>
						<Style>
							<Border>
								<Style>None</Style>
							</Border>
						</Style>
					</Textbox>

					<!-- Notes / Numbered Items -->
					<Textbox Name="TxtNotes">
						<CanGrow>true</CanGrow>
						<KeepTogether>true</KeepTogether>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>* Weighted average exchange rate of the month of remittance</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>2. As per instructions, transaction wise claim data has been uploaded on DAP.</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>3. Accordingly, it is requested to please credit the claim amount to our current account maintained with SBP BSC KO.</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
						<Top>2.4in</Top>
						<Left>0.25in</Left>
						<Height>0.9in</Height>
						<Width>6.5in</Width>
						<Style>
							<Border>
								<Style>None</Style>
							</Border>
						</Style>
					</Textbox>

					<!-- Head Home Remittances signature line -->
					<Line Name="LineHeadHR">
						<Top>4.6in</Top>
						<Left>0.25in</Left>
						<Height>0in</Height>
						<Width>1.7in</Width>
						<Style>
							<Border>
								<Color>Black</Color>
								<Style>Solid</Style>
								<Width>1pt</Width>
							</Border>
						</Style>
					</Line>

					<Textbox Name="TxtHeadHR">
						<CanGrow>true</CanGrow>
						<KeepTogether>true</KeepTogether>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Head Home Remittances</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
							</Paragraph>
						</Paragraphs>
						<Top>4.7in</Top>
						<Left>0.25in</Left>
						<Height>0.25in</Height>
						<Width>2.5in</Width>
						<Style>
							<Border>
								<Style>None</Style>
							</Border>
						</Style>
					</Textbox>

					<!-- Authorized Signatory 1 -->
					<Line Name="LineAuthSig1">
						<Top>5.7in</Top>
						<Left>0.25in</Left>
						<Height>0in</Height>
						<Width>1.7in</Width>
						<Style>
							<Border>
								<Color>Black</Color>
								<Style>Solid</Style>
								<Width>1pt</Width>
							</Border>
						</Style>
					</Line>

					<Textbox Name="TxtAuthSig1">
						<CanGrow>true</CanGrow>
						<KeepTogether>true</KeepTogether>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Authorized Signatory</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
								<Style>
									<TextAlign>Center</TextAlign>
								</Style>
							</Paragraph>
						</Paragraphs>
						<Top>5.8in</Top>
						<Left>0.25in</Left>
						<Height>0.25in</Height>
						<Width>1.7in</Width>
						<Style>
							<Border>
								<Style>None</Style>
							</Border>
						</Style>
					</Textbox>

					<!-- Authorized Signatory 2 -->
					<Line Name="LineAuthSig2">
						<Top>5.7in</Top>
						<Left>4.55in</Left>
						<Height>0in</Height>
						<Width>1.7in</Width>
						<Style>
							<Border>
								<Color>Black</Color>
								<Style>Solid</Style>
								<Width>1pt</Width>
							</Border>
						</Style>
					</Line>

					<Textbox Name="TxtAuthSig2">
						<CanGrow>true</CanGrow>
						<KeepTogether>true</KeepTogether>
						<Paragraphs>
							<Paragraph>
								<TextRuns>
									<TextRun>
										<Value>Authorized Signatory</Value>
										<Style>
											<FontFamily>Calibri</FontFamily>
											<FontSize>11pt</FontSize>
										</Style>
									</TextRun>
								</TextRuns>
								<Style>
									<TextAlign>Center</TextAlign>
								</Style>
							</Paragraph>
						</Paragraphs>
						<Top>5.8in</Top>
						<Left>4.55in</Left>
						<Height>0.25in</Height>
						<Width>1.7in</Width>
						<Style>
							<Border>
								<Style>None</Style>
							</Border>
						</Style>
					</Textbox>

				</ReportItems>
				<Height>6.3in</Height>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Body>
			<Width>7in</Width>
			<Page>
				<PageHeight>11in</PageHeight>
				<PageWidth>8.5in</PageWidth>
				<LeftMargin>0.75in</LeftMargin>
				<RightMargin>0.75in</RightMargin>
				<TopMargin>0.5in</TopMargin>
				<BottomMargin>0.5in</BottomMargin>
				<Style>
				</Style>
			</Page>
		</ReportSection>
	</ReportSections>
	<rd:ReportUnitType>Inch</rd:ReportUnitType>
	<rd:ReportID>a1b2c3d4-1234-5678-9abc-1234567890ab</rd:ReportID>
</Report>
