                <TextRuns>
                  <TextRun>
                    <Value>No claim/ transaction below the prescribed threshold of USD 200 or equivalent in other currencies has been included in the claims.</Value>
                    <Style>
                      <FontFamily>Calibri</FontFamily>
                      <FontSize>11pt</FontSize>
                    </Style>
