            </Paragraphs>
            <Top>2.45in</Top>
            <Left>0.5in</Left>
            <Height>0.4in</Height>
            <Width>0.3in</Width>
            <Style>
              <Border>
                <Style>None</Style>
              </Border>
            </Style>
          </Textbox>

          <Textbox Name="TxtPointIIBody">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>The FI and the overseas correspondent entity have not charged its customers any fee, commission or any other charges at any stage for processing the Home Remittance transaction.</Value>
                    <Style>
                      <FontFamily>Calibri</FontFamily>
                      <FontSize>11pt</FontSize>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>2.45in</Top>
            <Left>0.85in</Left>
            <Height>0.4in</Height>
            <Width>5.9in</Width>
            <Style>
              <Border>
                <Style>None</Style>
              </Border>
            </Style>
          </Textbox>

          <!-- Point iii. -->
          <Textbox Name="TxtPointIII">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>iii.</Value>
                    <Style>
                      <FontFamily>Calibri</FontFamily>
                      <FontSize>11pt</FontSize>
                    </Style>
