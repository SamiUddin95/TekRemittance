          </Textbox>

          <Textbox Name="TxtPointVIBody">
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>The claim(s) do not include transactions that pertain to:</Value>
                    <Style>
                      <FontFamily>Calibri</FontFamily>
                      <FontSize>11pt</FontSize>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>a. funds received or credited in RDA, as per EPD Circular Letter No. 11 of 2021 and related instructions issued by SBP from time to time;</Value>
                    <Style>
                      <FontFamily>Calibri</FontFamily>
                      <FontSize>11pt</FontSize>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>b. funds received or credited for Business-to-Customer (B2C), Customer-to-Business (C2B) and Business-to-Business (B2B) purposes, as per EPD Circular Letter No. 14 of 2022 and related instruction issued by SBP from;</Value>
                    <Style>
                      <FontFamily>Calibri</FontFamily>
                      <FontSize>11pt</FontSize>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>3.95in</Top>
            <Left>0.85in</Left>
            <Height>1.1in</Height>
            <Width>5.9in</Width>
            <Style>
              <Border>
                <Style>None</Style>
              </Border>
            </Style>
